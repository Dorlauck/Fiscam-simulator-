## 🧪 Tests Vitest — critère de succès

**Tous les cas de `07_EXAMPLES.md` doivent passer avec tolérance ±1%.**

Fichier cible : `tests/engine.*.test.ts`. Exemple :

```typescript
// tests/engine.france.test.ts
import { describe, it, expect } from "vitest";
import { calculateSASU } from "@/engine/structures/sasu-eurl";
import franceData from "@/data/france-2026.json";

describe("SASU Example 2A (CA 250k€)", () => {
  const input = {
    revenue: 250_000,
    businessExpenses: 50_000,
    salaryBrut: 60_000,
    dividendTarget: 80_000,
    familyStatus: "single" as const,
    children: 0,
  };
  const result = calculateSASU(input, franceData);

  it("total tax should be ~95,122 EUR (±1%)", () => {
    expect(result.totalTax).toBeGreaterThan(94_170);
    expect(result.totalTax).toBeLessThan(96_070);
  });

  it("net in hand should be ~95,878 EUR (±1%)", () => {
    expect(result.netInHand).toBeGreaterThan(94_919);
    expect(result.netInHand).toBeLessThan(96_837);
  });

  it("classification breakdown sums to social contributions", () => {
    const { effectivelyValuable, nominallyValuable, pureCost } = result.socialContributionsBreakdown;
    expect(effectivelyValuable + nominallyValuable + pureCost)
      .toBeCloseTo(result.socialContributions, 0);
  });
});
```

